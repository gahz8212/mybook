<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mybooks.mapper.BookMapper">

    <select id="findAll"  resultType="org.example.mybooks.dto.BookDto">
        select * from book
    </select>
    
    <insert id="create">
        insert into book(title,description,author,image,published)values(#{book.title},#{book.description},#{book.author},#{book.image},now())
    </insert>
    <select id="findById" resultType="org.example.mybooks.model.Book">
        select * from book where id=#{id}
    </select>
    <update id="update">
        update book set
        title=#{book.title},
        description=#{book.description},
        author=#{book.author}
        where id=#{id}
    </update>
    <delete id="delete">
        delete from book where id=#{id}
    </delete>
    <update id="updateFav">
        update book set favorite=favorite+1 where id=#{id}
    </update>

</mapper>